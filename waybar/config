{
  "layer": "top",
  "position": "top",

  "modules-left": ["custom/user"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["temperature", "custom/gpu", "memory", "custom/fan", "clock"],

  "custom/user": {
    "format": " masum@Arch ",
    "tooltip": false
  },

  "temperature": {
    "format": " {temperatureC}°C",
    "critical-threshold": 80
  },

  "custom/gpu": {
    "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
    "interval": 2,
    "format": " {}°C"
  },

  "memory": {
    "format": " {percentage}%"
  },

  "custom/fan": {
    "exec": "sensors | grep -i fan | head -n1 | awk '{print $2}'",
    "interval": 2,
    "format": " {}"
  },

  "clock": {
  "format": "{:%d-%m-%Y %H:%M:%S}",
  "interval": 1
}
}
