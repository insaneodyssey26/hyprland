{
  "layer": "top",
  "position": "top",
  "margin-top": 5,
  "margin-left": 10,
  "margin-right": 10,
  "height": 30,

  "modules-left": ["custom/user", "hyprland/workspaces","custom/thermals","custom/fan"],
  "modules-center": ["custom/media"],
  "modules-right": ["memory", "tray",  "network", "wireplumber", "battery", "clock"],

  // --- LEFT ---
  "custom/user": {
    "format": "َ°£‡",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "all-outputs": true,
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    }
  },

  // --- CENTER ---
  "custom/media": {
    "exec": "playerctl metadata --format '{{artist}} - {{title}}' 2>/dev/null",
    "interval": 1,
    "max-length": 30,
    "format": "َ°‌ڑ   {}",
    "on-click": "playerctl play-pause",
    "escape": true,  // This tells Waybar to handle characters like & safely
    "tooltip": false
  },

  // --- RIGHT ---
  "custom/thermals": {
    "exec": "echo \"$(cat /sys/class/hwmon/hwmon2/temp1_input | cut -c1-2)آ°C / $(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null)آ°C\"",
    "interval": 5,
    "format": "ï‹‰   {}",
    "tooltip": true,
    "tooltip-format": "CPU / GPU Temperature"
  },

  "memory": {
    "format": "َ°چ›   {percentage}%",
    "interval": 3
  },

  "tray": {
    "icon-size": 18,
    "spacing": 10
  },

  "custom/fan": {
    "exec": "echo \"$(cat /sys/class/hwmon/hwmon1/fan1_input) / $(cat /sys/class/hwmon/hwmon7/fan1_input) RPM\"",
    "interval": 2,
    "format": "َ°ˆگ   {}",
    "tooltip-format": "CPU / GPU Fan Speed"
  },

"network": { 
    "interval": 1,
    // {essid:.8} tells Waybar: "Show a maximum of 8 characters for the SSID"
    "format-wifi": "ï‡«    {essid:.10}  َ°“…   {bandwidthTotalBytes}",
    "format-ethernet": "َ°ˆ€    َ°“…   {bandwidthTotalBytes}",
    "format-disconnected": "َ°–ھ    Offline",
    "tooltip-format": "Full SSID: {essid}\nSignal: {signalStrength}%",
    "on-click": "nm-connection-editor",
    
    // Stability Anchor
    "min-length": 18,
    "max-length": 22,
    "align": 0
  },

  "wireplumber": { 
    "format": "{icon}   {volume}%", 
    "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"], 
    "on-click": "pavucontrol" 
  },

  "battery": {
    "bat": "BAT1",
    "adapter": "ACAD",
    "interval": 2,
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon}   {capacity}%",
    "format-charging": "َ±گ‹   {capacity}%",
    "format-plugged": "ï‡¦   {capacity}%",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "on-click": "rog-control-center"
  },

  "clock": { 
    "format": "َ°ƒ­   {:%d-%m    ï€—   %H:%M:%S}", 
    "interval": 1, 
    "on-click": "pkill gsimplecal || gsimplecal",
    "min-length": 15,
    "max-length": 21,
    "align": 0
  }
}
