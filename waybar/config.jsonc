{
  "layer": "top",
  "position": "top",
  "margin-top": 3,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "group/user-workspaces",
    "group/system-stats"
  ],

  "group/user-workspaces": {
    "orientation": "horizontal",
    "modules": ["custom/user", "hyprland/workspaces"]
  },
  "modules-center": ["mpris"],
  "modules-right": ["group/connectivity", "clock"],



  "group/system-stats": {
    "orientation": "horizontal",
    "modules": ["cpu", "memory", "custom/thermals"]
  },

  "group/connectivity": {
    "orientation": "horizontal",
    "modules": ["tray", "network", "wireplumber", "battery", "custom/keyboard"]
  },

  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "format": "{name}",
    "on-click": "hyprctl dispatch 'workspace {id}'",
    "persistent-workspaces": {
      "eDP-1": [1, 2, 3, 4, 5]
    }
  },

  "custom/keyboard": {
    "format": "ÔĄú ",
    "on-click": "~/.config/hypr/scripts/toggle_osk.sh",
    "tooltip": false
  },

  "cpu": {
    "interval": 3,
    "format": "Ôíľ   {usage}%",
    "on-click": "kitty -e btop",
    "on-click-right": "~/.config/waybar/sys_stats.sh"
  },

  "memory": {
    "interval": 3,
    "format": "ůįćõ   {percentage}%",
    "on-click": "kitty -e btop",
    "on-click-right": "~/.config/waybar/sys_stats.sh"
  },

  "custom/thermals": {
    "interval": 3,
    "format": "ÔčČ   {}",
    "exec": "echo \"$(awk '{print substr($1, 1, 2); exit}' /sys/class/hwmon/hwmon*/temp1_input 2>/dev/null)¬į / $(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null)¬į\"",
    "on-click": "kitty -e btop",
    "on-click-right": "~/.config/waybar/sys_stats.sh"
  },

  "network": {
    "interval": 3,
    "format-wifi": "Ôáę     {bandwidthTotalBytes}",
    "tooltip-format-wifi": "Network: {essid}",
    "on-click": "nm-connection-editor"
  },

  "wireplumber": {
    "format": "{icon}   {volume}%",
    "on-click": "pavucontrol",
    "format-icons": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
  },

  "battery": {
    "bat": "BAT1",
    "interval": 3,
    "format": "{icon}   {capacity}%",
    "format-icons": ["ÔČĄ ", "ÔČÉ ", "ÔČā ", "ÔČĀ ", "ÔČÄ "],
    "on-click": "rog-control-center"
  },

  "clock": {
    "format": "ůįÉ≠   {:%a, %d-%m   ůį•Ē   %H:%M:%S}",
    "interval": 1,
    "on-click": "kitty --class calendar-overlay --hold -e cal -y",
    "on-click-right": "kitty --class calendar-overlay -e tty-clock -c -C 5 -t -s"
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "custom/user": { "format": "ůį£á", "on-click": "swaync-client -t -sw" },
  "mpris": { "format": "ůįĚö   {title}", "max-length": 40 }
}