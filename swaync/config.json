{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "left",
  "positionY": "top",
  "control-center-margin-top": 10,
  "control-center-margin-left": 10,
  "control-center-width": 350,
  "control-center-radius": 14,
  "fit-to-screen": false,
  "transition-length": 200,
  "widgets": [
    "buttons-grid",
    "volume",
    "backlight",
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "System Dashboard",
      "clear-all-button": true,
      "button-text": "󰎟  Clear"
    },
    "volume": { 
      "label": "󰕾" 
    },
    "backlight": { 
      "label": "󰃠", 
      "device": "nvidia_0" 
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "",
          "command": "bash -c 'nmcli radio wifi | grep -q enabled && { nmcli radio wifi off; notify-send -t 2000 Wi-Fi Disabled -u low; } || { nmcli radio wifi on; notify-send -t 2000 Wi-Fi Enabled -u low; }' &"
        },
        {
          "label": "󰂯",
          "command": "blueman-manager"
        },
        {
          "label": "󰂛",
          "command": "swaync-client -d -sw"
        },
        {
          "label": "󰍬",
          "command": "bash -c 'wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle; sleep 0.1; wpctl get-mute @DEFAULT_AUDIO_SOURCE@ | grep -q MUTED && notify-send -t 2000 Microphone Muted -u low || notify-send -t 2000 Microphone Active -u low' &"
        },
        {
          "label": "󰐥",
          "command": "wlogout"
        },
        {
          "label": "󰃭",
          "command": "gsimplecal"
        }
      ]
    }
  }
}