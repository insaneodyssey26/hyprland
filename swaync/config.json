{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 12,
  "control-center-margin-bottom": 12,
  "control-center-margin-right": 12,
  "control-center-margin-left": 12,
  "control-center-width": 480,
  "control-center-height": 950,
  "fit-to-screen": false,
  "control-center-radius": 24,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-length": 400,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "title",
    "mpris",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "󰎟"
    },
    "dnd": {
      "text": "Focus Mode"
    },
    "mpris": {
      "image-size": 110,
      "image-radius": 18
    },
    "notifications": {
      "max-notifications": 12,
      "timeout": 6,
      "timeout-low": 2,
      "timeout-critical": 0
    }
  }
}