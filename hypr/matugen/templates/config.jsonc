{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "arch_small",
        "padding": { "top": 4, "left": 1 },
        "color": {
            "1": "#1793d1", 
            "2": "#1793d1"
        }
    },
    "display": { "separator": " " },
    "modules": [
        { "key": "╭───────────╮", "type": "custom", "keyColor": "{{colors.primary.default.hex}}" },
        
        { "key": "│  user    │", "type": "title", "format": "{user-name}", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰇅 hname   │", "type": "title", "format": "{host-name}", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰅐 uptime  │", "type": "uptime", "keyColor": "{{colors.primary.default.hex}}" },
        
        { "key": "├───────────┤", "type": "custom", "keyColor": "{{colors.primary.default.hex}}" }, 
        
        { "key": "│ 󰏖 pkgs    │", "type": "packages", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰣇 distro  │", "type": "os", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│  kernel  │", "type": "kernel", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│  wm      │", "type": "wm", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│  term    │", "type": "terminal", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│  shell   │", "type": "shell", "keyColor": "{{colors.primary.default.hex}}" },
        
        { "key": "├───────────┤", "type": "custom", "keyColor": "{{colors.primary.default.hex}}" }, 
        
        { "key": "│ 󰍛 cpu     │", "type": "cpu", "showPeCoreCount": true, "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰢮 gpu     │", "type": "gpu", "hideType": "integrated", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰉉 windows │", "type": "disk", "folders": "/mnt/windows", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰉉 linux   │", "type": "disk", "folders": "/", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│  memory  │", "type": "memory", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰓡 swap    │", "type": "swap", "keyColor": "{{colors.primary.default.hex}}" },
        { "key": "│ 󰁹 battery │", "type": "battery", "keyColor": "{{colors.primary.default.hex}}" },
        
        { "key": "╰───────────╯", "type": "custom", "keyColor": "{{colors.primary.default.hex}}" }
    ]
}
