{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "arch_small",
        "padding": { "top": 2, "left": 1 },
        "color": {
            "1": "#82d5c8", 
            "2": "#b1ccc6"
        }
    },
    "display": { "separator": " " },
    "modules": [
        { "key": "╭───────────╮", "type": "custom", "keyColor": "#899390" },
        
        { "key": "│  user    │", "type": "title", "format": "{user-name}", "keyColor": "#82d5c8" },
        { "key": "│ 󰇅 hname   │", "type": "title", "format": "{host-name}", "keyColor": "#82d5c8" },
        { "key": "│ 󰅐 uptime  │", "type": "uptime", "keyColor": "#82d5c8" },
        
        { "key": "├───────────┤", "type": "custom", "keyColor": "#899390" }, 
        
        { "key": "│ 󰏖 pkgs    │", "type": "packages", "keyColor": "#b1ccc6" },
        { "key": "│ 󰣇 distro  │", "type": "os", "keyColor": "#b1ccc6" },
        { "key": "│  kernel  │", "type": "kernel", "keyColor": "#b1ccc6" },
        { "key": "│  wm      │", "type": "wm", "keyColor": "#b1ccc6" },
        { "key": "│  term    │", "type": "terminal", "keyColor": "#b1ccc6" },
        { "key": "│  shell   │", "type": "shell", "keyColor": "#b1ccc6" },
        
        { "key": "├───────────┤", "type": "custom", "keyColor": "#899390" }, 
        
        { "key": "│ 󰍛 cpu     │", "type": "cpu", "showPeCoreCount": true, "keyColor": "#adcae6" },
        { "key": "│ 󰢮 gpu     │", "type": "gpu", "hideType": "integrated", "keyColor": "#adcae6" },
        { "key": "│ 󰉉 windows │", "type": "disk", "folders": "/mnt/windows", "keyColor": "#adcae6" },
        { "key": "│ 󰉉 linux   │", "type": "disk", "folders": "/", "keyColor": "#adcae6" },
        { "key": "│  memory  │", "type": "memory", "keyColor": "#adcae6" },
        { "key": "│ 󰓡 swap    │", "type": "swap", "keyColor": "#adcae6" },
        { "key": "│ 󰁹 battery │", "type": "battery", "keyColor": "#adcae6" },
        
        { "key": "╰───────────╯", "type": "custom", "keyColor": "#899390" }
    ]
}